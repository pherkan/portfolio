{% macro externallinklist(links) %}
  <ul class="external-link-list" aria-label="Elsewhere">
    {% for link in links %}
      <li class="external-link-list__item">
        {% if link.data.logo %}
          <img
            class="external-link-list__logo"
            src="{{ link.data.logo | url }}"
            alt=""
            loading="lazy"
            decoding="async"
          />
        {% elif link.data.sourceShort %}
          <span class="external-link-list__logo external-link-list__logo--text" aria-hidden="true">
            {{ link.data.sourceShort }}
          </span>
        {% else %}
          <span class="external-link-list__logo external-link-list__logo--placeholder" aria-hidden="true"></span>
        {% endif %}
        <a class="external-link-list__link" href="{{ link.data.externalUrl }}" target="_blank" rel="noopener noreferrer">
          {{ link.data.title }}
        </a>
      </li>
    {% endfor %}
  </ul>
{% endmacro %}
