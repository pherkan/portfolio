---
layout: base.njk
section: home
---
<div class="home-page">
	<div class="home-page__bg-square"></div>

  {# Hero #}
  <div class="hero">
    <div class="hero__col">
      {% if home.body %}
        <h1 class="hero__headline">{{ home.body | safe }}</h1>
      {% endif %}
      <ul class="hero-tags" aria-label="Focus areas">
        <li class="hero-tag">
          <span class="hero-tag__dot" aria-hidden="true"></span>
          <span>AI</span>
        </li>
        <li class="hero-tag">
          <span class="hero-tag__dot" aria-hidden="true"></span>
          <span>Automation</span>
        </li>
        <li class="hero-tag">
          <span class="hero-tag__dot" aria-hidden="true"></span>
          <span>Accessibility</span>
        </li>
        <li class="hero-tag">
          <span class="hero-tag__dot" aria-hidden="true"></span>
          <span>Product Strategy</span>
        </li>
        <li class="hero-tag">
          <span class="hero-tag__dot" aria-hidden="true"></span>
          <span>AI-assisted Prototyping</span>
        </li>
        <li class="hero-tag">
          <span class="hero-tag__dot" aria-hidden="true"></span>
          <span>0→1 Products</span>
        </li>
      </ul>
    </div>
  </div>

  {# Projects #}
  <div class="list-header">
    <h2 class="list-header__title">Projects</h2>
    <a class="btn btn--outline btn--sm" href="/projects" aria-label="View all projects">View All</a>
  </div>
  {% from "macros/projectcards.njk" import projectcards %}
  {{ projectcards(collections.project | reverse, 2, 'Featured projects', 'home-projects--featured') }}

  {# Blogposts #}
  <div class="list-header">
    <h2 class="list-header__title">Blogposts</h2>
    <a class="btn btn--outline btn--sm" href="/blog" aria-label="View all blogposts">View All</a>
  </div>
  {% from "macros/articlelist.njk" import articlelist %}
  {{ articlelist(
    articles = collections.post | reverse,
    show_tags = true,
    limit = 3
  ) }}

</div>
